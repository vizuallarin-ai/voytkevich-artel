# stroistroy.ru — production environment
# Copy to .env on VPS: cp .env.example .env

# ─── Site ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://stroistroy.ru
NODE_ENV=production

# ─── Storage (VPS default: file on persistent volume) ───────────────
# LEADS_STORAGE=file|supabase|auto   (auto = supabase if configured, else file)
# ANALYTICS_STORAGE=file|supabase|auto
LEADS_STORAGE=file
ANALYTICS_STORAGE=file
LEADS_FILE_STORE=true
ANALYTICS_FILE_STORE=true

# Optional Supabase (backup or primary DB instead of .data/)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── CRM dashboard ──────────────────────────────────────────────────
# Логин: stroistroy (или DASHBOARD_USERNAME)
DASHBOARD_USERNAME=stroistroy
DASHBOARD_PASSWORD=change-me-strong-password
# Старый способ (необязательно): длинный токен вместо пароля
# DASHBOARD_ACCESS_TOKEN=

# ─── Notifications ──────────────────────────────────────────────────
# Вариант A: Yandex SMTP (рекомендуется на Beget + почта на домене)
# LEADS_NOTIFICATION_EMAIL=info@stroistroy.ru
# EMAIL_FROM=info@stroistroy.ru
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=info@stroistroy.ru
# SMTP_PASS=пароль-приложения-yandex

# Вариант B: Telegram (рекомендуется для мгновенных уведомлений о заявках)
# TELEGRAM_BOT_TOKEN=123456:ABC...   — от @BotFather
# TELEGRAM_CHAT_ID=-1004302996579    — id ГРУППЫ (отрицательное число для supergroup)
# Бот должен быть добавлен в группу. Проверка: bash scripts/test-telegram.sh
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

LEADS_NOTIFICATION_EMAIL=
EMAIL_FROM=info@stroistroy.ru
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Вариант C: Resend (если не Yandex)
# RESEND_API_KEY=

# ─── Analytics (external) ───────────────────────────────────────────
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_GA_ID=

# ─── SLA ────────────────────────────────────────────────────────────
# LEADS_SLA_BUSINESS_HOURS=true

# ─── Rate limits (requests per IP per minute) ───────────────────────
LEADS_RATE_LIMIT=8
ANALYTICS_RATE_LIMIT=120

# ─── Dev only (never enable in production) ──────────────────────────
# LEADS_USE_DEMO=true
# ANALYTICS_USE_DEMO=true
